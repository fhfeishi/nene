########################################################################
# 1) 全局默认策略
########################################################################
* text=auto eol=lf

########################################################################
# 2) 强制二进制的文件
########################################################################
# 图片
*.png  -text
*.jpg  -text
*.jpeg -text
*.gif  -text
*.webp -text
*.ico  -text
*.bmp  -text

# 字体
*.eot  -text
*.ttf  -text
*.otf  -text
*.woff -text
*.woff2 -text

# 音频（语音 RAG 系统）
*.mp3  -text
*.wav  -text
*.ogg  -text
*.flac -text
*.aac  -text
*.m4a  -text

# 模型文件
*.bin  -text
*.onnx -text
*.pt   -text
*.pth  -text
*.safetensors -text
*.gguf -text
*.pkl  -text

# 文档（二进制格式）
*.pdf  -text
*.docx -text
*.doc  -text
*.xlsx -text

########################################################################
# 3) 源代码 — 强制文本 + LF
########################################################################
# 前端 (React / TypeScript)
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.svg  text eol=lf

# 后端 (Python / FastAPI)
*.py   text eol=lf
*.ipynb text eol=lf
# grpc
*.proto text eol=lf

########################################################################
# 4) 配置与数据文件 — 强制文本 + LF
########################################################################
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.csv   text eol=lf
*.xml   text eol=lf

# Shell & Docker（必须在 Linux 运行）
*.sh              text eol=lf
Dockerfile        text eol=lf
docker-compose.*  text eol=lf
.dockerignore     text eol=lf

# Python 锁文件（行尾影响哈希）
poetry.lock  text eol=lf
Pipfile      text eol=lf
Pipfile.lock text eol=lf

# Node.js 锁文件（行尾影响哈希）
package-lock.json text eol=lf
yarn.lock         text eol=lf
pnpm-lock.yaml    text eol=lf

# Git 自身
.gitignore     text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf

########################################################################
# 5) Windows 脚本 — 唯一需要 CRLF 的地方
########################################################################
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf